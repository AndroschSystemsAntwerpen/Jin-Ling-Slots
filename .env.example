# Web3 Configuration
# Copy this file to .env and fill in your values

# Solana RPC Endpoint
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# DocAndroschCoin (DAC) Mint Address
VITE_DAC_MINT=7FEUmYaUT1Ed6oFaRvrmpRr7YFg8DLjwxeX86qsx6TTK

# Token Decimals
VITE_DAC_DECIMALS=9

# Jupiter API (for swaps)
VITE_JUPITER_API=https://quote-api.jup.ag/v6

# Slippage tolerance (in basis points, 100 = 1%)
VITE_SLIPPAGE_BPS=100

# Use Devnet for testing (true/false)
VITE_USE_DEVNET=false

# Devnet RPC
VITE_DEVNET_RPC_URL=https://api.devnet.solana.com

# Game Configuration
VITE_MIN_BET=10
VITE_MAX_BET=10000
VITE_DEFAULT_BET=50

# Balance refresh interval (milliseconds)
VITE_BALANCE_REFRESH_INTERVAL=30000
